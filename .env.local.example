# ─── Sanity CMS ──────────────────────────────────────────────────────────────
# TODO: Add your Sanity project ID and dataset to enable CMS integration.
# If not set, the site falls back to /data/content.json
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# ─── Cloudinary (Optional image CDN) ─────────────────────────────────────────
# TODO: Set your Cloudinary cloud name to enable Cloudinary image optimization.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ─── Analytics ───────────────────────────────────────────────────────────────
# TODO: Set your Google Analytics measurement ID.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# TODO: Set your Plausible domain if using Plausible.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ─── Sentry ───────────────────────────────────────────────────────────────────
# TODO: Set your Sentry DSN for error monitoring.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ─── Contact Form ─────────────────────────────────────────────────────────────
# TODO: Add email/Resend/SendGrid credentials to send real emails from /api/contact
CONTACT_EMAIL_TO=you@example.com
RESEND_API_KEY=
